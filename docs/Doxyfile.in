PROJECT_NAME           = "Jiterati"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"
INPUT                  = @DOXYGEN_INPUT@
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.h *.cpp *.c *.md *.ebnf *.yaml
USE_MDFILE_AS_MAINPAGE = docs/frontpage.md
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
SEARCHENGINE           = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg
MARKDOWN_SUPPORT       = YES
WARN_IF_UNDOCUMENTED   = NO
QUIET                  = NO
